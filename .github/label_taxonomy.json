{
  "surfaces": [
    {
      "name": "kernel",
      "option": "Kernel / policy / approvals",
      "color": "0b5fff",
      "description": "Kernel policy, approvals, and audit surfaces.",
      "paths": [
        "crates/kernel/**"
      ]
    },
    {
      "name": "contracts",
      "option": "Contracts",
      "color": "1d76db",
      "description": "Shared contract and type surfaces.",
      "paths": [
        "crates/contracts/**"
      ]
    },
    {
      "name": "protocol",
      "option": "Protocol",
      "color": "0366d6",
      "description": "Protocol crate and wire-level behavior.",
      "paths": [
        "crates/protocol/**"
      ]
    },
    {
      "name": "spec",
      "option": "Spec / architecture boundaries",
      "color": "6f42c1",
      "description": "Architecture boundaries, product specs, and design docs.",
      "paths": [
        "crates/spec/**",
        "docs/design-docs/**",
        "docs/product-specs/**"
      ]
    },
    {
      "name": "daemon",
      "option": "Daemon / CLI / install",
      "color": "5319e7",
      "description": "Daemon binary, CLI entrypoints, and install flow.",
      "paths": [
        "crates/daemon/**",
        "scripts/install.sh",
        "scripts/install.ps1"
      ]
    },
    {
      "name": "providers",
      "option": "Providers / routing",
      "color": "0e8a16",
      "description": "Provider routing, selection, and transport behavior.",
      "paths": [
        "crates/app/src/provider/**",
        "crates/app/src/config/provider.rs"
      ]
    },
    {
      "name": "tools",
      "option": "Tools",
      "color": "0f766e",
      "description": "Tool runtime, policy adapters, and tool catalog behavior.",
      "paths": [
        "crates/app/src/tools/**"
      ]
    },
    {
      "name": "browser",
      "option": "Browser automation",
      "color": "0ea5e9",
      "description": "Browser automation surfaces and related tooling.",
      "paths": [
        "crates/app/src/tools/browser.rs"
      ]
    },
    {
      "name": "channels",
      "option": "Channels / integrations",
      "color": "16a34a",
      "description": "Channel adapters and external integration surfaces.",
      "paths": [
        "crates/app/src/channel/**",
        "crates/app/src/feishu/**"
      ]
    },
    {
      "name": "memory",
      "option": "Memory / context assembly",
      "color": "a855f7",
      "description": "Memory system, context assembly, and persistence flow.",
      "paths": [
        "crates/app/src/memory/**",
        "crates/app/src/config/memory.rs"
      ]
    },
    {
      "name": "conversation",
      "option": "Conversation / session runtime",
      "color": "d946ef",
      "description": "Conversation runtime, session flow, and prompt assembly.",
      "paths": [
        "crates/app/src/conversation/**",
        "crates/app/src/prompt/**",
        "crates/app/src/session/**",
        "crates/app/src/config/conversation.rs"
      ]
    },
    {
      "name": "config",
      "option": "Config",
      "color": "f59e0b",
      "description": "Runtime config parsing, schema, and defaults.",
      "paths": [
        "crates/app/src/config/**",
        "crates/spec/config/**"
      ]
    },
    {
      "name": "acp",
      "option": "ACP control plane",
      "color": "ec4899",
      "description": "ACP manager, binding, routing, and control plane surfaces.",
      "paths": [
        "crates/app/src/acp/**"
      ]
    },
    {
      "name": "migration",
      "option": "Migration / onboarding",
      "color": "f97316",
      "description": "Onboarding, legacy import, and migration flow.",
      "paths": [
        "crates/app/src/migration/**"
      ]
    },
    {
      "name": "docs",
      "option": "Docs / contributor workflow",
      "color": "0891b2",
      "description": "Contributor docs, references, and issue/PR guidance.",
      "paths": [
        "docs/references/**",
        "README.md",
        "README.zh-CN.md",
        "CONTRIBUTING.md",
        "SECURITY.md",
        "CODE_OF_CONDUCT.md",
        ".github/ISSUE_TEMPLATE/**",
        ".github/PULL_REQUEST_TEMPLATE.md"
      ]
    },
    {
      "name": "ci",
      "option": "CI / release / workflows",
      "color": "ea580c",
      "description": "CI, workflows, release automation, and repo governance scripts.",
      "paths": [
        ".github/workflows/**",
        ".github/dependabot.yml",
        ".github/labeler.yml",
        ".github/label_taxonomy.json",
        "Taskfile.yml",
        "scripts/architecture_budget_lib.sh",
        "scripts/bootstrap_release_local_artifacts.sh",
        "scripts/check*.sh",
        "scripts/generate_architecture_drift_report.sh",
        "scripts/lint_*.sh",
        "scripts/release_artifact_lib.sh",
        "scripts/sync_github_labels.py",
        "scripts/test_*.sh"
      ]
    }
  ],
