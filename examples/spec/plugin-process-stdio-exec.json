{
  "pack": {
    "pack_id": "process-stdio-exec-pack",
    "domain": "platform",
    "version": "0.1.0",
    "default_route": {
      "harness_kind": "EmbeddedPi",
      "adapter": "pi-local"
    },
    "allowed_connectors": [],
    "granted_capabilities": [],
    "metadata": {
      "owner": "platform-team",
      "stage": "bridge-runtime"
    }
  },
  "agent_id": "agent-process-stdio-exec",
  "ttl_s": 120,
  "defaults": null,
  "self_awareness": null,
