    "allow_mcp_server_auto_apply": false,
    "block_unverified_high_risk_auto_apply": false,
    "enforce_ready_execution": true,
    "max_tasks": 8
  },
  "auto_provision": null,
  "hotfixes": [],
  "operation": {
    "kind": "connector_legacy",
    "connector_name": "stdio-echo",
    "operation": "echo",
    "required_capabilities": [
      "InvokeConnector"
    ],
    "payload": {
      "message": "hello-from-stdio-bridge"
    }
  }
